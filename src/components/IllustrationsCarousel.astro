---
const illustrations = [
  { src: "/images/portfolio/mansion-scene-color.jpg", title: "Mansion Scene", category: "Background Art" },
  { src: "/images/portfolio/scene-3-colors.jpg", title: "Forest Scene", category: "Background Art" },
  { src: "/images/portfolio/outside-scene.jpg", title: "Outside Scene", category: "Background Art" },
  { src: "/images/portfolio/tree-foliage-exploration.png", title: "Tree Foliage Study", category: "Environment Design" },
  { src: "/images/portfolio/bg-art-7.png", title: "Interior Scene", category: "Background Art" },
  { src: "/images/portfolio/bg-art-5.png", title: "Atmospheric Scene", category: "Background Art" },
  { src: "/images/portfolio/bg-art-12.png", title: "Landscape", category: "Background Art" },
  { src: "/images/portfolio/kotn-bg30.jpg", title: "KOTN Background", category: "Production Art" },
  { src: "/images/portfolio/dj-bedroom.jpg", title: "DJ's Bedroom", category: "Background Art" },
  { src: "/images/portfolio/scene-4.jpg", title: "Scene IV", category: "Background Art" },
];
---

<section id="illustrations" class="py-20 md:py-28">
  <div class="max-w-5xl mx-auto px-6 md:px-12 mb-12">
    <div class="section-divider">
      <span class="divider-ornament">&#x2726;&#x2726;</span>
      <span class="divider-ornament">&#x2726;&#x2726;</span>
    </div>
    <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-center text-charcoal-800 tracking-wide">
      ILLUSTRATIONS
    </h2>
    <div class="h-px bg-warmgold-400/30 mt-6"></div>
  </div>

  <!-- Carousel -->
  <div class="relative group/carousel">
    <div id="carousel" class="flex gap-4 md:gap-6 overflow-x-auto scroll-container px-6 md:px-12 snap-x snap-mandatory pb-4">
      {illustrations.map((item) => (
        <div class="snap-start shrink-0 w-[80vw] sm:w-[60vw] md:w-[45vw] lg:w-[35vw]">
          <div class="card-hover group rounded-sm overflow-hidden aspect-[16/10]" data-lightbox data-lightbox-src={item.src} data-lightbox-alt={item.title}>
            <img
              src={item.src}
              alt={item.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="card-overlay">
              <div>
                <p class="font-sans text-[10px] tracking-[0.2em] uppercase text-cream-200/70 mb-1">{item.category}</p>
                <h3 class="font-display text-lg md:text-xl text-cream-50">{item.title}</h3>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Scroll arrows -->
    <button
      id="carousel-prev"
      class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-cream-100/90 backdrop-blur-sm border border-warmgold-400/30 flex items-center justify-center text-warmgold-500 hover:bg-warmgold-500 hover:text-cream-50 transition-all opacity-0 group-hover/carousel:opacity-100 z-10"
      aria-label="Previous"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button
      id="carousel-next"
      class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-cream-100/90 backdrop-blur-sm border border-warmgold-400/30 flex items-center justify-center text-warmgold-500 hover:bg-warmgold-500 hover:text-cream-50 transition-all opacity-0 group-hover/carousel:opacity-100 z-10"
      aria-label="Next"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <div class="text-center mt-10">
    <a href="#projects" class="btn-primary">More Work</a>
  </div>
</section>

<script>
  const carousel = document.getElementById("carousel")!;
  const scrollAmount = carousel.offsetWidth * 0.6;

  document.getElementById("carousel-prev")!.addEventListener("click", () => {
    carousel.scrollBy({ left: -scrollAmount, behavior: "smooth" });
  });
  document.getElementById("carousel-next")!.addEventListener("click", () => {
    carousel.scrollBy({ left: scrollAmount, behavior: "smooth" });
  });
</script>
