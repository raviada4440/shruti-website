---
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-16">
  <!-- Background illustration -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/portfolio/mansion-scene-color.jpg"
      alt=""
      class="w-full h-full object-cover opacity-25 scale-105"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-cream-100/80 via-cream-100/40 to-cream-100"></div>
  </div>

  <!-- Name & title -->
  <div class="relative z-10 text-center px-6 opacity-0 animate-hero-fade">
    <div class="mb-6">
      <div class="w-24 h-24 md:w-32 md:h-32 mx-auto mb-6 rounded-full border-2 border-warmgold-400/40 flex items-center justify-center">
        <span class="font-display text-warmgold-500 text-4xl md:text-5xl">S</span>
      </div>

      <!-- Circular text badge -->
      <div class="relative inline-block mb-4">
        <svg class="w-40 h-40 md:w-52 md:h-52 mx-auto" viewBox="0 0 200 200">
          <defs>
            <path id="circlePath" d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0" fill="none" />
          </defs>
          <text class="fill-warmgold-400 text-[11px] md:text-[12px] tracking-[0.35em] uppercase" style="font-family: 'DM Sans', sans-serif;">
            <textPath href="#circlePath" startOffset="0%">
              illustrator • background artist • designer •
            </textPath>
          </text>
        </svg>
      </div>
    </div>

    <h1 class="font-display text-5xl sm:text-6xl md:text-8xl lg:text-9xl text-charcoal-800 tracking-wide leading-none mb-4">
      SHRUTI<br />ADA
    </h1>

    <div class="h-px w-32 md:w-48 bg-warmgold-400/50 mx-auto my-6"></div>

    <p class="font-sans text-sm md:text-base tracking-[0.2em] uppercase text-charcoal-700/70">
      Backgrounds &bull; Props &bull; Illustration &bull; Design
    </p>

    <div class="mt-12">
      <a href="#illustrations" class="inline-flex items-center gap-2 text-warmgold-500 font-sans text-xs tracking-[0.15em] uppercase hover:gap-4 transition-all duration-300">
        View Work
        <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </a>
    </div>
  </div>

  <!-- Bottom decorative edge -->
  <div class="absolute bottom-0 left-0 right-0 z-10">
    <svg class="w-full" viewBox="0 0 1440 60" fill="none" preserveAspectRatio="none">
      <path d="M0 60V30C240 0 480 50 720 30C960 10 1200 50 1440 30V60H0Z" class="fill-cream-100"/>
    </svg>
  </div>
</section>
