---
import type { PortfolioItem } from "../data/portfolio";

interface Props {
  id: string;
  title: string;
  subtitle: string;
  images: PortfolioItem[];
  viewMoreHref: string;
  learnMoreHref?: string;
}

const { id, title, subtitle, images, viewMoreHref, learnMoreHref } = Astro.props;
---

<section id={id} class="py-16 md:py-24 overflow-hidden">
  <!-- Section header -->
  <div class="max-w-[1366px] mx-auto px-6 md:px-12 text-center mb-8 md:mb-12">
    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5.5rem] leading-[1.05] tracking-tight">
      {title}
    </h2>
    <p class="font-body text-base sm:text-lg md:text-xl mt-3 md:mt-4">
      {subtitle}
    </p>
  </div>

  <!-- Marquee strip -->
  <div class="marquee-container relative">
    <div class="marquee-track flex gap-4 md:gap-6">
      {/* First set */}
      {images.map((item) => (
        <div
          class="marquee-item flex-shrink-0 w-[280px] sm:w-[320px] md:w-[380px] lg:w-[440px] cursor-pointer group"
          data-lightbox
          data-lightbox-src={item.src}
          data-lightbox-alt={item.alt}
        >
          <div class="overflow-hidden rounded-sm">
            <img
              src={item.src}
              alt={item.alt}
              class="w-full h-[180px] sm:h-[200px] md:h-[230px] lg:h-[260px] object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {images.map((item) => (
        <div
          class="marquee-item flex-shrink-0 w-[280px] sm:w-[320px] md:w-[380px] lg:w-[440px] cursor-pointer group"
          data-lightbox
          data-lightbox-src={item.src}
          data-lightbox-alt={item.alt}
          aria-hidden="true"
        >
          <div class="overflow-hidden rounded-sm">
            <img
              src={item.src}
              alt={item.alt}
              class="w-full h-[180px] sm:h-[200px] md:h-[230px] lg:h-[260px] object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>

    {/* Learn more overlay on third image */}
    {learnMoreHref && (
      <a
        href={learnMoreHref}
        class="absolute top-1/2 right-[30%] -translate-y-1/2 font-body text-lg md:text-xl text-black/80 hover:text-black transition-colors hidden md:block"
      >
        learn more
      </a>
    )}
  </div>

  <!-- View more link -->
  <div class="max-w-[1366px] mx-auto px-6 md:px-12 mt-6 md:mt-8 text-center">
    <a
      href={viewMoreHref}
      class="font-body text-lg md:text-xl text-black/70 hover:text-black transition-colors duration-300 inline-block"
    >
      view more
    </a>
  </div>
</section>

<style>
  .marquee-container {
    width: 100%;
    overflow: hidden;
  }

  .marquee-track {
    animation: marquee-scroll var(--marquee-duration, 45s) linear infinite;
    width: max-content;
  }

  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
