---
---

<section id="contact" class="py-20 md:py-28 bg-cream-200/50">
  <div class="max-w-3xl mx-auto px-6 md:px-12">
    <div class="section-divider">
      <span class="divider-ornament">&#x2726;&#x2726;</span>
      <span class="divider-ornament">&#x2726;&#x2726;</span>
    </div>
    <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-center text-charcoal-800 tracking-wide">
      LET'S WORK TOGETHER
    </h2>
    <div class="h-px bg-warmgold-400/30 mt-6 mb-6"></div>

    <p class="text-center font-body text-base md:text-lg text-charcoal-700 leading-relaxed mb-4">
      Have a project in mind? Feel free to reach out via the form below,<br class="hidden md:block" />
      or email me directly at
      <a href="mailto:shrutiada19@gmail.com" class="text-warmgold-500 hover:text-warmgold-600 transition-colors underline underline-offset-4 decoration-warmgold-400/40">
        shrutiada19@gmail.com
      </a>
    </p>
    <p class="text-center font-sans text-sm text-charcoal-700/60 mb-12">
      Let's create something beautiful together.
    </p>

    <!-- 
      For Netlify hosting: add netlify attribute to <form>
      For Formspree: change action to https://formspree.io/f/YOUR_ID 
    -->
    <form name="contact" method="POST" data-netlify="true" class="space-y-6">
      <input type="hidden" name="form-name" value="contact" />

      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label for="name" class="block font-sans text-xs tracking-[0.15em] uppercase text-charcoal-700/70 mb-2">Name *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full bg-transparent border border-warmgold-400/30 rounded-sm px-4 py-3 font-body text-charcoal-800 placeholder:text-charcoal-700/30 focus:outline-none focus:border-warmgold-500 transition-colors"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="block font-sans text-xs tracking-[0.15em] uppercase text-charcoal-700/70 mb-2">Email *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full bg-transparent border border-warmgold-400/30 rounded-sm px-4 py-3 font-body text-charcoal-800 placeholder:text-charcoal-700/30 focus:outline-none focus:border-warmgold-500 transition-colors"
            placeholder="your@email.com"
          />
        </div>
      </div>

      <div>
        <label for="subject" class="block font-sans text-xs tracking-[0.15em] uppercase text-charcoal-700/70 mb-2">What's this regarding? *</label>
        <input
          type="text"
          id="subject"
          name="subject"
          required
          class="w-full bg-transparent border border-warmgold-400/30 rounded-sm px-4 py-3 font-body text-charcoal-800 placeholder:text-charcoal-700/30 focus:outline-none focus:border-warmgold-500 transition-colors"
          placeholder="Background art, illustration, design..."
        />
      </div>

      <div>
        <label for="message" class="block font-sans text-xs tracking-[0.15em] uppercase text-charcoal-700/70 mb-2">Message *</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full bg-transparent border border-warmgold-400/30 rounded-sm px-4 py-3 font-body text-charcoal-800 placeholder:text-charcoal-700/30 focus:outline-none focus:border-warmgold-500 transition-colors resize-vertical"
          placeholder="Tell me about your project..."
        ></textarea>
      </div>

      <div class="text-center pt-2">
        <button type="submit" class="btn-primary">
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>
