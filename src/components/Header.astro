---
const navLinks = [
  { href: "/illustrations", label: "illustration" },
  { href: "/works", label: "works" },
  { href: "/services", label: "services" },
  { href: "/about", label: "about" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-5">
  <nav class="max-w-[1366px] mx-auto hidden md:flex items-center justify-between">
    <div class="flex items-center gap-12 lg:gap-20">
      {navLinks.slice(0, 2).map((link) => (
        <a
          href={link.href}
          class="font-body text-lg lg:text-xl text-black/80 hover:text-black transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </div>
    <a href="/" class="nav-logo">
      <img src="/images/shruti-ada-logo.png" alt="Shruti Ada" class="nav-logo-img" />
    </a>
    <div class="flex items-center gap-12 lg:gap-20">
      {navLinks.slice(2).map((link) => (
        <a
          href={link.href}
          class="font-body text-lg lg:text-xl text-black/80 hover:text-black transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>

  <!-- Mobile header bar -->
  <div class="mobile-header-bar md:hidden">
    <a href="/" class="mobile-logo">
      <img src="/images/shruti-ada-logo.png" alt="Shruti Ada" class="mobile-logo-img" />
    </a>
    <button id="menu-toggle" class="mobile-menu-trigger" aria-label="Toggle menu">
      <span class="mobile-view-more">view more</span>
      <img src="/images/doodles/m-header-arrow.png" alt="" class="mobile-view-arrow" />
      <img src="/images/doodles/m-header-hanging.png" alt="" class="mobile-header-doodle" />
    </button>
  </div>
</header>

<nav
  id="mobile-nav"
  class="fixed inset-0 z-50 flex items-start justify-center opacity-0 pointer-events-none transition-all duration-500 md:hidden"
>
  <div class="mobile-nav-overlay"></div>
  <div class="mobile-nav-content">
    <a href="/" class="mobile-nav-logo">
      <img src="/images/shruti-ada-logo.png" alt="Shruti Ada" class="mobile-nav-logo-img" />
    </a>
    <img src="/images/doodles/m-header-hanging.png" alt="" class="mobile-nav-doodle" />
    <ul class="mobile-nav-links">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .nav-logo:hover { opacity: 0.6; }
  .nav-logo-img {
    width: 6vw;
    height: auto;
  }

  /* Mobile header bar */
  .mobile-header-bar {
    display: none;
    align-items: flex-start;
    justify-content: space-between;
    padding: 0 4vw;
    position: relative;
  }
  .mobile-logo-img {
    width: 30.8vw;
    height: auto;
  }
  .mobile-menu-trigger {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 60;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    width: 56vw;
    height: 38vw;
  }
  .mobile-view-more {
    position: absolute;
    left: 2vw;
    top: 17vw;
    font-family: "Sugarpie", cursive;
    font-size: 5.1vw;
    font-weight: 400;
    color: black;
  }
  .mobile-view-arrow {
    position: absolute;
    left: 17vw;
    top: 8vw;
    width: 25vw;
    object-fit: contain;
  }
  .mobile-header-doodle {
    position: absolute;
    right: 1vw;
    top: 0;
    width: 21.6vw;
  }

  /* Mobile nav overlay */
  .mobile-nav-overlay {
    position: absolute;
    inset: 0;
    background-color: #d8d4cf;
    background-image: url("/images/paper-bg.jpg");
    background-size: cover;
    background-position: center;
  }
  .mobile-nav-content {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    padding: 4.3vw 1.3vw 0;
  }
  .mobile-nav-logo {
    display: inline-block;
  }
  .mobile-nav-logo-img {
    width: 44.3vw;
    height: auto;
  }
  .mobile-nav-doodle {
    position: absolute;
    top: 0;
    right: 1vw;
    width: 21.6vw;
    pointer-events: none;
  }
  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: center;
    margin-top: 28vw;
    display: flex;
    flex-direction: column;
    gap: 8vw;
  }
  .mobile-nav-link {
    font-family: "Sugarpie", cursive;
    font-size: 6.11vw;
    font-weight: 400;
    color: black;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .mobile-nav-link:hover {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .mobile-header-bar {
      display: flex;
    }
  }
</style>
