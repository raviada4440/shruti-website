---
/**
 * A secondary gallery strip showing more work in a compact masonry-like layout.
 * Sits between the main carousel and the about section.
 */
const images = [
  { src: "/images/portfolio/bg-art-8.png", alt: "Background art" },
  { src: "/images/portfolio/bg-art-13.png", alt: "Background art" },
  { src: "/images/portfolio/kotn-bg26.jpg", alt: "KOTN background" },
  { src: "/images/portfolio/bg-art-11.png", alt: "Background art" },
  { src: "/images/portfolio/bg-art-14.png", alt: "Background art" },
  { src: "/images/portfolio/prop-3b.png", alt: "Prop design" },
  { src: "/images/portfolio/bg-art-8b.png", alt: "Background art" },
  { src: "/images/portfolio/bg-art-4.png", alt: "Background art" },
  { src: "/images/portfolio/pdl-presentation.jpg", alt: "Presentation" },
  { src: "/images/portfolio/bg-art-13b.png", alt: "Background art" },
];
---

<section class="py-16 md:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="columns-2 md:columns-3 lg:columns-4 gap-3 md:gap-4">
      {images.map((img, i) => (
        <div class="break-inside-avoid mb-3 md:mb-4">
          <div class="card-hover rounded-sm overflow-hidden">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="card-overlay">
              <p class="font-sans text-xs tracking-wider uppercase text-cream-100/80">View</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
