<section id="about" class="py-20 md:py-28">
  <div class="max-w-5xl mx-auto px-6 md:px-12">
    <div class="section-divider">
      <span class="divider-ornament">&#x2726;&#x2726;</span>
      <span class="divider-ornament">&#x2726;&#x2726;</span>
    </div>

    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mt-12">
      <!-- Image -->
      <div class="relative">
        <div class="aspect-[4/5] rounded-sm overflow-hidden">
          <img
            src="/images/portfolio/scene-3-colors.jpg"
            alt="Shruti Ada artwork"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-2 border-warmgold-400/30 rounded-sm -z-10"></div>
      </div>

      <!-- Text -->
      <div>
        <h2 class="font-display text-4xl md:text-5xl text-charcoal-800 tracking-wide mb-2">
          HELLO!
        </h2>
        <div class="h-px w-16 bg-warmgold-400/50 mb-8"></div>

        <div class="space-y-5 font-body text-base md:text-lg text-charcoal-700 leading-relaxed">
          <p>
            I'm <strong class="text-charcoal-900">Shruti Ada</strong>, a background artist, 
            prop designer, illustrator &amp; graphic designer.
          </p>
          <p>
            I specialize in creating rich, atmospheric environments and detailed prop designs 
            for animation. My work has included background art and prop design for animated 
            productions, bringing stories to life through color, light, and composition.
          </p>
          <p>
            I also offer illustration and graphic design services &mdash; from editorial 
            illustrations and character design to branding, identity systems, and visual 
            storytelling.
          </p>
          <p class="text-warmgold-600 font-sans text-sm tracking-wide">
            <!-- Shruti: Update this with your real bio! -->
            Currently open for freelance work and collaborations.
          </p>
        </div>

        <div class="mt-8">
          <a href="#contact" class="btn-primary">Get In Touch</a>
        </div>
      </div>
    </div>
  </div>
</section>
