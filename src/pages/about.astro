---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Shruti Ada">
  <div class="about-page">

    <!-- Hero area with photos and intro -->
    <section class="about-hero">
      <img src="/images/doodles/about-doodle-topleft.png" alt="" class="doodle doodle-topleft" />
      <h1 class="about-title">learn about me!</h1>
      <img src="/images/about/doodle-top-right.png" alt="" class="doodle doodle-topright" />

      <div class="photo-grid">
        <img src="/images/about/photo-1.png" alt="Shruti Ada" class="photo photo-left" />
        <p class="intro-tagline">texan raised</p>
        <p class="intro-name">as you know my name is shruti</p>
        <img src="/images/about/photo-2.png" alt="Shruti Ada" class="photo photo-right" />
      </div>

      <div class="intro-text-left">
        <p class="intro-nickname">many know me as "shroot"
(like groot)</p>
        <p class="intro-bio">I'm an illustrator and designer based in California who genuinely, embarrassingly cares about the work I make for people.</p>
      </div>
    </section>

    <!-- Extended bio -->
    <section class="about-bio">
      <p class="bio-text">I came up as an illustrator first, which means I see every design problem through an artist's lens. Where most designers think in grids and guidelines, I think in stories, characters, and visuals that make people feel something. That perspective is what makes the work different. And honestly? It's what makes it fun.

Whether you're building a brand from scratch, need a website that finally looks like you, or just want your Instagram to stop looking like a cry for help, I got you.</p>
    </section>

    <!-- Likes section -->
    <section class="about-likes">
      <p class="likes-heading">just some of my likes for fun</p>
      <div class="likes-scatter">
        <span class="like-item" style="left: 14.3vw; top: 0;">soup</span>
        <span class="like-item" style="left: 43.3vw; top: 2vw;">dancing</span>
        <span class="like-item" style="left: 79.4vw; top: 0;">beans</span>
        <span class="like-item" style="left: 28.1vw; top: 10vw;">movies</span>
        <span class="like-item" style="left: 57.1vw; top: 10vw;">board games</span>
      </div>
      <img src="/images/doodles/about-doodle-likes.png" alt="" class="doodle doodle-likes" />
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <h2 class="cta-heading">if you still want to work with me after all of that... you're a keeper</h2>
      <p class="cta-label">contact me here:</p>
      <a href="mailto:shrutiada19@gmail.com" class="cta-email">shrutiada19@gmail.com</a>
      <img src="/images/doodles/about-doodle-bottom.png" alt="" class="doodle doodle-bottom" />
    </section>

  </div>
</BaseLayout>

<style>
  .about-page {
    width: 100%;
    overflow: hidden;
  }

  /* Hero */
  .about-hero {
    position: relative;
    padding: 6vw 4vw 0;
  }

  .about-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.1758vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
  }

  .doodle {
    position: absolute;
    object-fit: contain;
    pointer-events: none;
  }

  .doodle-topleft {
    left: 0.8vw;
    top: 4vw;
    width: 17.9vw;
  }

  .doodle-topright {
    position: absolute;
    right: 0.4vw;
    top: 4vw;
    width: 20vw;
    object-fit: contain;
    pointer-events: none;
  }

  /* Photo grid */
  .photo-grid {
    position: relative;
    margin-top: 4vw;
    min-height: 48vw;
  }

  .photo {
    position: absolute;
    object-fit: cover;
  }

  .photo-left {
    left: 5.7vw;
    top: 0;
    width: 40.2vw;
    height: 27.8vw;
  }

  .photo-right {
    right: 10.8vw;
    top: 20vw;
    width: 37.1vw;
    height: 37.1vw;
  }

  .intro-tagline {
    position: absolute;
    left: 64vw;
    top: 0;
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
  }

  .intro-name {
    position: absolute;
    left: 56vw;
    top: 12vw;
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
  }

  .intro-text-left {
    padding: 2vw 0 0 6vw;
    max-width: 40vw;
  }

  .intro-nickname {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    white-space: pre-line;
  }

  .intro-bio {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 3vw;
  }

  /* Bio */
  .about-bio {
    padding: 6vw 11vw;
  }

  .bio-text {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.5;
    white-space: pre-line;
    max-width: 78.2vw;
  }

  /* Likes */
  .about-likes {
    position: relative;
    padding: 4vw 4vw 8vw;
  }

  .likes-heading {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }

  .likes-scatter {
    position: relative;
    height: 16vw;
    margin-top: 3vw;
  }

  .like-item {
    position: absolute;
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
  }

  .doodle-likes {
    right: 2vw;
    top: -2vw;
    width: 28.3vw;
  }

  /* CTA */
  .about-cta {
    position: relative;
    padding: 6vw 4vw 10vw;
    text-align: center;
  }

  .cta-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.1758vw;
    font-weight: 500;
    line-height: 1.057;
    max-width: 80vw;
    margin: 0 auto;
  }

  .cta-label {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.1758vw;
    font-weight: 500;
    line-height: 1.057;
    margin-top: 6vw;
  }

  .cta-email {
    display: block;
    font-family: "Sugarpie", cursive;
    font-size: 4.1758vw;
    font-weight: 400;
    text-decoration: none;
    color: inherit;
    margin-top: 2vw;
    transition: opacity 0.3s;
  }

  .cta-email:hover {
    opacity: 0.7;
  }

  .doodle-bottom {
    position: relative;
    display: block;
    margin: 4vw auto 0;
    width: 32.5vw;
  }
</style>
