---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Services — Shruti Ada">
  <div class="services-page">

    <div class="services-hero">
      <h1 class="services-title" data-typewriter>Services</h1>
      <p class="services-subtitle">curious as to what i can offer you?</p>
      <p class="services-subtitle">well its branding, illustrations & iconography, social media content, and website design</p>
    </div>

    <!-- Branding -->
    <section class="service-block service-left">
      <h2 class="service-heading"><span class="service-heading-text" data-typewriter>branding</span><span class="accordion-arrow">&#x25BC;</span></h2>
      <div class="service-body">
        <p class="service-text align-left">Let's make your business unforgettable. (In the good way.)

You know that feeling when a brand just gets it? The logo, the colors, the whole vibe feels so right it's almost annoying? Yeah, that's what we're going for. Through research, art direction, and an illustrator's brain that never really clocks out, I build brand identities that turn heads and actually reflect who you are. No cookie-cutter anything. Just your brand, but make it iconic.

Includes: Art Direction, Market Research, Logo Design & Brand Identity</p>
      </div>
      <img src="/images/doodles/services-doodle-1.png" alt="" class="service-doodle doodle-branding" />
    </section>

    <!-- Illustrations & Iconography -->
    <section class="service-block service-right">
      <h2 class="service-heading align-right"><span class="service-heading-text" data-typewriter>+illustrations
+=and Iconography</span><span class="accordion-arrow">&#x25BC;</span></h2>
      <div class="service-body">
        <p class="service-text align-right">This is my love language. Seriously.

Ask me to draw something and watch my eyes light up like a kid on Christmas. As an illustrator first, this is where I'm fully in my element, editorial pieces that make people stop and stare, custom icon sets that give your brand its own visual personality, and artwork that couldn't have come from anyone else. Stock illustrations? We don't know her.

Includes: Editorial Illustration, Custom Iconography, Commercial & Conceptual Artwork</p>
      </div>
      <img src="/images/doodles/services-doodle-2.png" alt="" class="service-doodle doodle-illustration" />
    </section>

    <!-- Social Media Content -->
    <section class="service-block service-left">
      <h2 class="service-heading"><span class="service-heading-text" data-typewriter>social media content</span><span class="accordion-arrow">&#x25BC;</span></h2>
      <div class="service-body">
        <p class="service-text align-left">A website so you,(your mom) will finally understand what you do.

No more "so what is it exactly that you make?" Your website should feel like walking into your world, not borrowing someone else's template and hoping for the best. I design UI experiences that are clean, beautiful, and easy to navigate because looking good and making sense shouldn't be mutually exclusive. And yes, the illustrator brain makes everything more interesting. You're welcome.

Includes: UI Design, Layout & Visual Hierarchy, Brand-Aligned Web Experience</p>
      </div>
    </section>

    <!-- Website Design -->
    <section class="service-block service-right">
      <h2 class="service-heading align-right"><span class="service-heading-text" data-typewriter>website design</span><span class="accordion-arrow">&#x25BC;</span></h2>
      <div class="service-body">
        <p class="service-text align-right">Because "I'll just post something later" is not a strategy.

We've all been there. Staring at a blank grid wondering why nothing looks right. That's where I come in. From posts and story graphics to event invites and email headers, I create content that's cohesive, on-brand, and way too good to scroll past. Your audience will think you have a whole creative team. It'll be our little secret.

Includes: Social Media Graphics, Post Templates, Digital Invitations, Email Headers & Banners</p>
      </div>
    </section>

    <!-- Interested CTA -->
    <section class="interested-section">
      <div class="interested-text">
        <h2 class="interested-heading" data-typewriter>Interested?</h2>
        <p class="interested-sub">thank god.</p>
        <p class="interested-label">email me here:</p>
        <a href="mailto:shrutiada19@gmail.com" class="interested-email">shrutiada19@gmail.com</a>
      </div>
      <img src="/images/doodles/services-doodle-3.png" alt="" class="interested-doodle" />
    </section>

    <!-- Bottom scroll section -->
    <section class="bottom-section">
      <h2 class="bottom-heading" data-typewriter>if you wanna scroll</h2>
      <div class="bottom-links">
        <a href="https://www.instagram.com" target="_blank" rel="noopener" class="bottom-link">instagram</a>
        <a href="https://www.linkedin.com" target="_blank" rel="noopener" class="bottom-link">linkedin</a>
      </div>
      <img src="/images/doodles/services-doodle-3.png" alt="" class="bottom-doodle" />
    </section>

  </div>
</BaseLayout>

<style>
  .services-page {
    width: 100%;
    overflow: hidden;
  }

  /* Hero */
  .services-hero {
    padding: 6vw 0 4vw;
    text-align: center;
  }

  .services-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
  }

  .services-subtitle {
    font-family: "Sugarpie", cursive;
    font-size: 1.7582vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 1vw;
  }

  /* Service blocks */
  .service-block {
    position: relative;
    padding: 4vw 4.25vw;
  }

  .service-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    white-space: pre-line;
  }

  .service-left .service-heading {
    text-align: left;
  }

  .service-right .service-heading {
    text-align: right;
  }

  .service-body {
    margin-top: 2vw;
  }

  .service-text {
    font-family: "Sugarpie", cursive;
    font-size: 1.7582vw;
    font-weight: 400;
    line-height: 1.5;
    white-space: pre-line;
    max-width: 91.7vw;
  }

  .align-left {
    text-align: left;
  }

  .align-right {
    text-align: right;
  }

  /* Doodles */
  .service-doodle {
    position: absolute;
    object-fit: contain;
    pointer-events: none;
  }

  .doodle-branding {
    left: 3.5vw;
    bottom: -18vw;
    width: 22vw;
  }

  .doodle-illustration {
    right: 3vw;
    bottom: -20vw;
    width: 24vw;
  }

  /* Interested CTA */
  .interested-section {
    position: relative;
    padding: 8vw 4.25vw 6vw;
    min-height: 50vw;
  }

  .interested-text {
    position: relative;
    z-index: 1;
  }

  .interested-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
  }

  .interested-sub {
    font-family: "Sugarpie", cursive;
    font-size: 1.7582vw;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
    margin-top: 2vw;
  }

  .interested-label {
    font-family: "Sugarpie", cursive;
    font-size: 1.7582vw;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
    margin-top: 6vw;
  }

  .interested-email {
    display: block;
    font-family: "Sugarpie", cursive;
    font-size: 2.6374vw;
    font-weight: 400;
    text-align: center;
    text-decoration: none;
    color: inherit;
    margin-top: 0.5vw;
    transition: opacity 0.3s;
  }

  .interested-email:hover {
    opacity: 0.7;
  }

  .interested-doodle {
    position: absolute;
    right: -10vw;
    top: 5vw;
    width: 50.9vw;
    object-fit: contain;
    pointer-events: none;
  }

  /* Bottom section */
  .bottom-section {
    padding: 6vw 0 8vw;
    text-align: center;
  }

  .bottom-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
  }

  .bottom-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5vw;
    margin-top: 4vw;
  }

  .bottom-link {
    font-family: "Sugarpie", cursive;
    font-size: 2.6374vw;
    font-weight: 400;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.3s;
  }

  .bottom-link:hover {
    opacity: 0.7;
  }

  .accordion-arrow {
    display: none;
  }

  .bottom-doodle {
    display: none;
  }

  @media (max-width: 768px) {
    .services-hero {
      padding: 38vw 6vw 4vw;
    }
    .services-title {
      font-size: 9.16vw;
    }
    .services-subtitle {
      font-size: 4.07vw;
      margin-top: 2vw;
    }

    .service-block {
      padding: 4vw 6vw;
    }
    .service-heading {
      font-size: 9.16vw;
      text-align: left !important;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 3vw;
    }
    .service-heading-text {
      flex: 1;
    }
    .accordion-arrow {
      display: inline-block;
      font-size: 4vw;
      transition: transform 0.3s;
      flex-shrink: 0;
    }
    .service-heading.is-open .accordion-arrow {
      transform: rotate(180deg);
    }

    .service-body {
      display: none;
      margin-top: 3vw;
    }
    .service-body.is-open {
      display: block;
    }
    .service-text {
      font-size: 4.07vw;
      text-align: left !important;
      max-width: 100%;
    }

    .service-doodle { display: none; }

    .interested-section {
      padding: 10vw 6vw 0;
      min-height: auto;
    }
    .interested-heading {
      font-size: 8.14vw;
      text-align: center;
    }
    .interested-sub {
      font-size: 4.07vw;
      text-align: center;
    }
    .interested-label {
      font-size: 4.07vw;
      text-align: center;
      margin-top: 1vw;
    }
    .interested-email {
      font-size: 4.07vw;
      text-align: center;
    }
    .interested-doodle {
      display: none;
    }

    .bottom-section {
      padding: 2vw 6vw 10vw;
      text-align: center;
      position: relative;
    }
    .bottom-heading {
      font-size: 8.14vw;
      text-align: center;
    }
    .bottom-links {
      align-items: center;
      gap: 3vw;
      margin-top: 4vw;
    }
    .bottom-link {
      font-size: 4.07vw;
    }
    .bottom-doodle {
      display: block;
      width: 35vw;
      margin: -18vw 0 0 auto;
    }
  }
</style>

<script>
  if (window.matchMedia('(max-width: 768px)').matches) {
    document.querySelectorAll('.service-heading').forEach((heading) => {
      heading.addEventListener('click', () => {
        const body = heading.nextElementSibling;
        if (!body) return;
        const isOpen = body.classList.contains('is-open');
        document.querySelectorAll('.service-body').forEach((b) => b.classList.remove('is-open'));
        document.querySelectorAll('.service-heading').forEach((h) => h.classList.remove('is-open'));
        if (!isOpen) {
          body.classList.add('is-open');
          heading.classList.add('is-open');
        }
      });
    });
  }

  const els = document.querySelectorAll('[data-typewriter]');
  const speed = 45;
  els.forEach((el) => {
    const fullText = el.textContent || '';
    const speed = parseInt(el.getAttribute('data-typewriter-speed') || '80', 10);
    const rect = el.getBoundingClientRect();
    const alreadyVisible = rect.top < window.innerHeight && rect.bottom > 0;

    if (alreadyVisible) return;

    el.textContent = '';
    el.style.visibility = 'visible';
    let typed = false;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !typed) {
          typed = true;
          observer.unobserve(el);
          let i = 0;
          const tick = () => {
            if (i <= fullText.length) {
              el.textContent = fullText.slice(0, i);
              i++;
              setTimeout(tick, speed);
            }
          };
          tick();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(el);
  });
</script>
