---
import BaseLayout from "../layouts/BaseLayout.astro";

const illustrations = [
  { src: "/images/portfolio/mansion-scene-color.jpg", alt: "Monster House" },
  { src: "/images/portfolio/forest-scene.jpg", alt: "Forest Scene" },
  { src: "/images/portfolio/outside-scene.jpg", alt: "Outside Scene" },
  { src: "/images/portfolio/interior-scene.jpg", alt: "Interior Scene" },
];

const projects = [
  { src: "/images/portfolio/mansion-scene-color.jpg", alt: "Monster House" },
  { src: "/images/portfolio/forest-scene.jpg", alt: "Forest Scene" },
  { src: "/images/portfolio/landscape.jpg", alt: "Landscape" },
  { src: "/images/portfolio/kotn-bg.jpg", alt: "KOTN Production" },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="min-h-[90vh] flex flex-col justify-center max-w-[1366px] mx-auto px-6 md:px-12 relative">
    <div class="flex flex-col md:flex-row items-start gap-8 md:gap-16">
      <div class="flex-1">
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[96px] leading-[1.05] tracking-tight">
          Welcome to the<br />inside of my brain
        </h1>
        <p class="font-body text-xl md:text-2xl mt-6 max-w-xl">
          (My name is Shruti Ada and I'm an illustrator + Graphic Designer)
        </p>
      </div>
      <div class="flex-shrink-0 w-48 md:w-72 self-center md:self-start">
        <img src="/images/doodles/creature-1.png" alt="" class="w-full" />
      </div>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="py-16 md:py-24 max-w-[1366px] mx-auto px-6 md:px-12">
    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-[96px] leading-[1.05] tracking-tight text-center max-w-5xl mx-auto">
      Every project gets my whole heart, not just my hands
    </h2>
    <p class="font-body text-xl md:text-[27px] text-center mt-8 max-w-2xl mx-auto">
      My works are my babies, I raise them from the ground up
    </p>
  </section>

  <!-- Illustrations -->
  <section class="py-16 md:py-20 max-w-[1366px] mx-auto px-6 md:px-12">
    <h2 class="text-5xl md:text-6xl lg:text-[96px] leading-[1.05] tracking-tight text-center mb-4">
      illustrations
    </h2>
    <p class="font-body text-xl md:text-[27px] text-center mb-10">
      ( a plethora of illustrative art works here)
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {illustrations.map((item) => (
        <div
          class="group relative overflow-hidden cursor-pointer"
          data-lightbox
          data-lightbox-src={item.src}
          data-lightbox-alt={item.alt}
        >
          <img
            src={item.src}
            alt={item.alt}
            class="w-full h-48 md:h-56 object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div class="flex justify-between items-center mt-6">
      <a href="/gallery" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity">view more</a>
      <a href="/gallery" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity">learn more</a>
    </div>
  </section>

  <!-- Projects -->
  <section class="py-16 md:py-20 max-w-[1366px] mx-auto px-6 md:px-12">
    <h2 class="text-5xl md:text-6xl lg:text-[96px] leading-[1.05] tracking-tight text-center mb-4">
      projects
    </h2>
    <p class="font-body text-xl md:text-[27px] text-center mb-10">
      ( a plethora of projects art works here)
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      {projects.map((item) => (
        <div
          class="group relative overflow-hidden cursor-pointer"
          data-lightbox
          data-lightbox-src={item.src}
          data-lightbox-alt={item.alt}
        >
          <img
            src={item.src}
            alt={item.alt}
            class="w-full h-48 md:h-56 object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div class="mt-6">
      <a href="/gallery" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity">view more</a>
    </div>
  </section>

  <!-- Say Hello -->
  <section class="py-20 md:py-32 max-w-[1366px] mx-auto px-6 md:px-12">
    <h2 class="text-5xl md:text-6xl lg:text-[96px] leading-[1.05] tracking-tight text-center">
      Say Hello!
    </h2>
    <p class="font-body text-xl md:text-[27px] text-center mt-4">
      I promise I dont bite.....maybe
    </p>

    <div class="flex flex-col md:flex-row items-center justify-between gap-12 mt-16">
      <div>
        <h3 class="text-3xl md:text-4xl lg:text-[64px] leading-[1.05]">
          Lets collaborate<br />and have fun
        </h3>
        <div class="mt-8 space-y-2">
          <p class="font-body text-xl md:text-[27px]">contact me</p>
          <a href="mailto:shrutiada19@gmail.com" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity underline">
            shrutiada19@gmail.com
          </a>
        </div>
      </div>
      <div class="flex-shrink-0">
        <img src="/images/doodles/stickfigure-1.png" alt="" class="w-40 md:w-56" />
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-black/10">
      <a href="mailto:shrutiada19@gmail.com" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity">
        Shrutiada19@gmail.com
      </a>
      <a href="https://www.instagram.com" target="_blank" rel="noopener" class="font-body text-xl md:text-[27px] hover:opacity-60 transition-opacity">
        social media
      </a>
    </div>
  </section>
</BaseLayout>
