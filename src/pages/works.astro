---
import BaseLayout from "../layouts/BaseLayout.astro";
import { works } from "../data/portfolio";
---

<BaseLayout title="Works — Shruti Ada">
  <div class="gallery-page">

    <h1 class="gallery-title">works</h1>
    <div class="gallery-doodle-wrap">
      <img src="/images/doodles/gallery-doodle.png" alt="" class="gallery-doodle" />
    </div>

    <div class="marquee-wrap marquee-rtl">
      <div class="marquee-track">
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item" aria-hidden="true" tabindex="-1">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
      </div>
    </div>

    <div class="marquee-wrap marquee-ltr">
      <div class="marquee-track">
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item" aria-hidden="true" tabindex="-1">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
      </div>
    </div>

    <div class="marquee-wrap marquee-rtl">
      <div class="marquee-track">
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
        {works.map((item) => (
          <a href={`/works/${item.slug}`} class="marquee-item" aria-hidden="true" tabindex="-1">
            <img src={item.src} alt={item.alt} loading="lazy" />
          </a>
        ))}
      </div>
    </div>

    <footer class="gallery-footer">
      <div class="gallery-footer-doodles">
        <img src="/images/doodles/m-illust-footer-creature-l.png" alt="" class="footer-doodle footer-doodle-left" />
        <img src="/images/doodles/m-illust-footer-creature-r.png" alt="" class="footer-doodle footer-doodle-right" />
      </div>
      <div class="gallery-footer-nav">
        <a href="/illustrations" class="footer-nav-link">illustrations</a>
        <a href="/about" class="footer-nav-link">about</a>
      </div>
      <div class="gallery-footer-bar">
        <a href="mailto:shrutiada19@gmail.com" class="footer-bar-link">shrutiada19@gmail.com</a>
        <a href="https://www.instagram.com" target="_blank" rel="noopener" class="footer-bar-link">social media</a>
      </div>
    </footer>

  </div>
</BaseLayout>

<style>
  .gallery-page {
    width: 100%;
    padding-top: 6vw;
    overflow: hidden;
  }

  .gallery-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
  }

  .gallery-doodle-wrap {
    margin-top: 1.5vw;
    margin-bottom: 4vw;
    padding-left: 6vw;
  }

  .gallery-doodle {
    width: 10vw;
    object-fit: contain;
  }

  .marquee-wrap {
    width: 100%;
    overflow: hidden;
    margin-bottom: 2vw;
  }

  .marquee-track {
    display: flex;
    gap: 1.7570vw;
    width: max-content;
  }

  .marquee-rtl .marquee-track {
    animation: scroll-rtl 160s linear infinite;
  }

  .marquee-ltr .marquee-track {
    animation: scroll-ltr 160s linear infinite;
  }

  .marquee-wrap:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    flex-shrink: 0;
    width: 32.5769vw;
    display: block;
    text-decoration: none;
    cursor: pointer;
    overflow: hidden;
    border-radius: 2px;
  }

  .marquee-item img {
    width: 100%;
    height: 18.3162vw;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .marquee-item:hover img {
    transform: scale(1.03);
  }

  @keyframes scroll-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scroll-ltr {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .gallery-footer { display: none; }

  @media (max-width: 768px) {
    .gallery-page { padding-top: 38vw; }

    .gallery-title {
      font-size: 9.16vw;
      text-align: center;
      padding-left: 0;
    }

    .gallery-doodle-wrap {
      margin-top: 0;
      margin-bottom: 6vw;
      padding-left: 2vw;
    }
    .gallery-doodle { width: 44vw; }

    .marquee-item { width: 46.1vw; }
    .marquee-item img { height: 26vw; }
    .marquee-wrap { margin-bottom: 3vw; }

    .gallery-footer {
      display: block;
      padding: 12vw 6vw 8vw;
    }
    .gallery-footer-doodles {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .footer-doodle {
      object-fit: contain;
      pointer-events: none;
    }
    .footer-doodle-left { width: 19.1vw; }
    .footer-doodle-right { width: 16.5vw; }
    .gallery-footer-nav {
      display: flex;
      justify-content: space-between;
      margin-top: 4vw;
    }
    .gallery-footer-bar {
      display: flex;
      justify-content: space-between;
      margin-top: 6vw;
    }
    .footer-nav-link,
    .footer-bar-link {
      font-family: "Sugarpie", cursive;
      font-size: 4.07vw;
      font-weight: 400;
      color: inherit;
      text-decoration: none;
      transition: opacity 0.3s;
    }
    .footer-nav-link:hover,
    .footer-bar-link:hover { opacity: 0.6; }
  }
</style>
