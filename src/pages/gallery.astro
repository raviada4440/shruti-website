---
import BaseLayout from "../layouts/BaseLayout.astro";

const illustrations = [
  { src: "/images/portfolio/mansion-scene-color.jpg", alt: "Mansion Scene" },
  { src: "/images/portfolio/forest-scene.jpg", alt: "Forest Scene" },
  { src: "/images/portfolio/outside-scene.jpg", alt: "Outside Scene" },
  { src: "/images/portfolio/tree-foliage.jpg", alt: "Tree Foliage Study" },
  { src: "/images/portfolio/interior-scene.jpg", alt: "Interior Scene" },
  { src: "/images/portfolio/atmospheric-scene.jpg", alt: "Atmospheric Scene" },
  { src: "/images/portfolio/landscape.jpg", alt: "Landscape" },
  { src: "/images/portfolio/kotn-bg.jpg", alt: "KOTN Background" },
  { src: "/images/portfolio/dj-bedroom.jpg", alt: "DJ's Bedroom" },
  { src: "/images/portfolio/scene-iv.jpg", alt: "Scene IV" },
];

const projects = [
  { src: "/images/portfolio/mansion-scene-color.jpg", alt: "In The Shadows" },
  { src: "/images/portfolio/forest-scene.jpg", alt: "Monster House" },
  { src: "/images/portfolio/outside-scene.jpg", alt: "Legally Blonde" },
  { src: "/images/portfolio/landscape.jpg", alt: "KOTN Production" },
  { src: "/images/portfolio/interior-scene.jpg", alt: "Environment Studies" },
  { src: "/images/portfolio/atmospheric-scene.jpg", alt: "Animated Shorts" },
  { src: "/images/portfolio/kotn-bg.jpg", alt: "Background Art" },
  { src: "/images/portfolio/tree-foliage.jpg", alt: "Prop Design" },
];
---

<BaseLayout title="Gallery — Shruti Ada">
  <div class="max-w-[1366px] mx-auto px-6 md:px-12 py-8 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20">
      <!-- Illustrations column -->
      <div>
        <div class="flex items-center gap-4 mb-8">
          <img src="/images/doodles/owl-1.png" alt="" class="w-12 h-12" />
          <h1 class="text-4xl md:text-5xl lg:text-[64px] leading-[1.05]">Illustrations</h1>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {illustrations.map((item) => (
            <div
              class="group relative overflow-hidden cursor-pointer"
              data-lightbox
              data-lightbox-src={item.src}
              data-lightbox-alt={item.alt}
            >
              <img
                src={item.src}
                alt={item.alt}
                class="w-full h-40 md:h-48 object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Projects column -->
      <div>
        <div class="flex items-center justify-between mb-8">
          <h1 class="text-4xl md:text-5xl lg:text-[64px] leading-[1.05]">Projects</h1>
          <a href="/case-study/avid-biologics" class="font-body text-lg hover:opacity-60 transition-opacity">case study →</a>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {projects.map((item) => (
            <div
              class="group relative overflow-hidden cursor-pointer"
              data-lightbox
              data-lightbox-src={item.src}
              data-lightbox-alt={item.alt}
            >
              <img
                src={item.src}
                alt={item.alt}
                class="w-full h-40 md:h-48 object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
