---
import BaseLayout from "../../layouts/BaseLayout.astro";

const socialPosts = [
  { src: "/images/case-study/new-hire-office-hours.png", alt: "New Hire Office Hours" },
  { src: "/images/case-study/momentum-athletic.png", alt: "Momentum Athletic Club" },
  { src: "/images/case-study/benefits-office-hours.png", alt: "Benefits Office Hours" },
  { src: "/images/case-study/go-observation-winners.png", alt: "GO Observation Winners" },
];

const presentations = [
  { src: "/images/case-study/avelocity-4.png", alt: "AVelocity Presentation" },
  { src: "/images/case-study/avelocity-3.png", alt: "AVelocity Slide" },
  { src: "/images/case-study/av-7.png", alt: "AV-7 Presentation" },
  { src: "/images/case-study/protein-a-cover.png", alt: "Protein A Cover" },
];
---

<BaseLayout title="Avid Biologics — Shruti Ada">
  <div class="max-w-[1366px] mx-auto px-6 md:px-12 py-8 md:py-12">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-5xl md:text-6xl lg:text-[64px] leading-[1.05]">avid Biologics</h1>
    </div>

    <!-- Description -->
    <div class="max-w-3xl mx-auto mb-12">
      <p class="font-body text-lg md:text-xl leading-relaxed text-center">
        Avid biologics is a biotech company that produces biologics. I'm in charge with supplementing with their social media and branding. Creating posts for linkedin and work for their offices, as well as illustrations to make them stand out against their competitors
      </p>
      <p class="font-body text-lg md:text-xl text-center mt-4 italic">
        (see, i can do corporate too!)
      </p>
    </div>

    <!-- Hero image -->
    <div class="mb-12">
      <img
        src="/images/case-study/webinar-slide.png"
        alt="Webinar Slide Design"
        class="w-full max-w-4xl mx-auto"
        data-lightbox
        data-lightbox-src="/images/case-study/webinar-slide.png"
        data-lightbox-alt="Webinar Slide Design"
      />
    </div>

    <!-- Social media posts grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {socialPosts.map((item) => (
        <div
          class="cursor-pointer"
          data-lightbox
          data-lightbox-src={item.src}
          data-lightbox-alt={item.alt}
        >
          <img src={item.src} alt={item.alt} class="w-full object-cover" loading="lazy" />
        </div>
      ))}
    </div>

    <!-- Presentation designs -->
    <div class="mb-16">
      <h2 class="font-body text-2xl md:text-[32px] text-center mb-8">presentation designs</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {presentations.map((item) => (
          <div
            class="cursor-pointer"
            data-lightbox
            data-lightbox-src={item.src}
            data-lightbox-alt={item.alt}
          >
            <img src={item.src} alt={item.alt} class="w-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
