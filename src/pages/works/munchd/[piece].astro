---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { munchdPieces } from "../../../data/portfolio";

export function getStaticPaths() {
  return munchdPieces.map((p) => ({
    params: { piece: p.piece },
  }));
}

const { piece } = Astro.params;
const current = munchdPieces.find((p) => p.piece === piece)!;
---

<BaseLayout title={`${current.title} — munch'd — Shruti Ada`}>
  <div class="piece-page">
    <nav class="piece-nav" aria-label="Breadcrumb">
      <a href="/works" class="piece-nav-link">works</a>
      <span class="piece-nav-sep" aria-hidden="true">/</span>
      <a href="/works/munchd" class="piece-nav-link">munch'd</a>
      <span class="piece-nav-sep" aria-hidden="true">/</span>
      <span class="piece-nav-current">{current.title}</span>
    </nav>

    <h1 class="piece-title">{current.title}</h1>

    <div class="piece-hero">
      <img src={current.src} alt={current.title} class="piece-img" />
    </div>

    <p class="piece-see-all">
      <a href="/works/munchd" class="piece-link">See full munch'd project →</a>
    </p>
  </div>
</BaseLayout>

<style>
  .piece-page {
    width: 100%;
    overflow: hidden;
    padding: 6vw 8vw 8vw;
  }

  .piece-nav {
    font-family: "Sugarpie", cursive;
    font-size: 1.7582vw;
    font-weight: 400;
    margin-bottom: 3vw;
    text-align: center;
  }

  .piece-nav-link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .piece-nav-link:hover {
    opacity: 0.6;
  }

  .piece-nav-sep {
    margin: 0 0.8vw;
    opacity: 0.5;
  }

  .piece-nav-current {
    opacity: 0.75;
  }

  .piece-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.1758vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
    margin-bottom: 4vw;
  }

  .piece-hero {
    max-width: 72vw;
    margin: 0 auto;
  }

  .piece-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  .piece-see-all {
    margin-top: 4vw;
    text-align: center;
  }

  .piece-link {
    font-family: "Sugarpie", cursive;
    font-size: 2.0513vw;
    font-weight: 400;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .piece-link:hover {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .piece-page {
      padding: 28vw 6vw 12vw;
    }
    .piece-nav {
      font-size: 3.8vw;
    }
    .piece-title {
      font-size: 7.5vw;
    }
    .piece-hero {
      max-width: none;
    }
    .piece-link {
      font-size: 4vw;
    }
  }
</style>
