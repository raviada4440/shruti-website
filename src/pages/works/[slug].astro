---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { works } from "../../data/portfolio";

export function getStaticPaths() {
  return works.map((item) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;
const current = works.find((w) => w.slug === slug)!;
---

<BaseLayout title={`${current.title} — Shruti Ada`}>
  <div class="works-detail">

    <div class="project-info">
      <h1 class="project-title">{current.title}</h1>
      {current.description && (
        <p class="project-description">{current.description}</p>
      )}
      {current.subtitle && (
        <p class="project-subtitle">{current.subtitle}</p>
      )}
    </div>

    {current.sections.map((section) =>
      section.type === "full-width" ? (
        <div class="section-fullwidth">
          {section.images.map((img, i) => (
            <img src={img} alt={`${current.title} — ${i + 1}`} class="fullwidth-img" />
          ))}
        </div>
      ) : section.type === "marquee" ? (
        <div class="marquee-wrap marquee-rtl">
          <div class="marquee-track">
            {section.images.map((img, i) => (
              <div class="marquee-item" data-swap-src={img}>
                <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" />
              </div>
            ))}
            {section.images.map((img, i) => (
              <div class="marquee-item" data-swap-src={img} aria-hidden="true">
                <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="section-masonry">
          {section.label && <p class="section-label">{section.label}</p>}
          <div class="masonry-grid">
            {section.images.map((img, i) => (
              <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" class="masonry-img" />
            ))}
          </div>
        </div>
      )
    )}

    <div class="cta-section">
      <h2 class="cta-heading">Like what you see?</h2>
      <img src="/images/doodles/individual-doodle-2.png" alt="" class="cta-doodle-arrow" />
      <p class="cta-subheading">contact me!</p>
      <a href="mailto:shrutiada19@gmail.com" class="cta-email">shrutiada19@gmail.com</a>
      <img src="/images/doodles/individual-doodle-1.png" alt="" class="cta-doodle-monster" />
    </div>

  </div>
</BaseLayout>

<style>
  .works-detail {
    width: 100%;
    overflow: hidden;
  }

  .project-info {
    padding: 6vw 8vw 4vw;
    text-align: center;
  }

  .project-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
  }

  .project-description {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 2vw;
    text-align: center;
    max-width: 72vw;
    margin-left: auto;
    margin-right: auto;
  }

  .project-subtitle {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 2vw;
    text-align: center;
  }

  /* Full-width section */
  .section-fullwidth {
    padding: 3vw 8.3vw;
  }

  .fullwidth-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Marquee section */
  .marquee-wrap {
    width: 100%;
    overflow: hidden;
    padding: 3vw 0;
  }

  .marquee-track {
    display: flex;
    gap: 1.757vw;
    width: max-content;
  }

  .marquee-rtl .marquee-track {
    animation: scroll-rtl 140s linear infinite;
  }

  .marquee-wrap:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    flex-shrink: 0;
    width: 40vw;
    overflow: hidden;
    border-radius: 2px;
    cursor: pointer;
  }

  .marquee-item img {
    width: 100%;
    height: 22vw;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .marquee-item:hover img {
    transform: scale(1.03);
  }

  /* Masonry section */
  .section-masonry {
    padding: 3vw 4vw;
  }

  .section-label {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    text-align: left;
    margin-bottom: 2vw;
    padding-left: 0.5vw;
  }

  .masonry-grid {
    columns: 2;
    column-gap: 2vw;
  }

  .masonry-img {
    width: 100%;
    margin-bottom: 2vw;
    break-inside: avoid;
    display: block;
  }

  /* CTA section */
  .cta-section {
    position: relative;
    padding: 4vw 0 6vw;
    min-height: 57vw;
    overflow: visible;
  }

  .cta-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
  }

  .cta-doodle-arrow {
    position: absolute;
    left: 6vw;
    top: 5.8vw;
    width: 30vw;
    object-fit: contain;
    pointer-events: none;
  }

  .cta-subheading {
    position: relative;
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
    margin-top: 12vw;
  }

  .cta-email {
    position: relative;
    display: block;
    margin-top: 1vw;
    font-family: "Sugarpie", cursive;
    font-size: 3.5139vw;
    font-weight: 400;
    text-decoration: none;
    color: inherit;
    text-align: center;
    transition: opacity 0.3s;
  }

  .cta-email:hover {
    opacity: 0.7;
  }

  .cta-doodle-monster {
    position: absolute;
    right: -4vw;
    top: 14vw;
    width: 37vw;
    object-fit: contain;
    pointer-events: none;
  }

  @keyframes scroll-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  const fullwidthImg = document.querySelector('.fullwidth-img') as HTMLImageElement;
  if (fullwidthImg) {
    document.querySelectorAll('[data-swap-src]').forEach((el) => {
      el.addEventListener('click', () => {
        const src = (el as HTMLElement).dataset.swapSrc;
        if (src) {
          fullwidthImg.src = src;
          fullwidthImg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });
  }
</script>
