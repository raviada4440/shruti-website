---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { works } from "../../data/portfolio";

export function getStaticPaths() {
  return works
    .filter((item) => item.slug !== "munchd")
    .map((item) => ({
      params: { slug: item.slug },
    }));
}

const { slug } = Astro.params;
const current = works.find((w) => w.slug === slug)!;
---

<BaseLayout title={`${current.title} — Shruti Ada`}>
  <div
    class:list={[
      "works-detail",
      current.slug === "avid-bioservices" && "works-detail--avid-bio",
      current.slug === "red-water" && "works-detail--red-water",
    ]}
  >

    <div class="project-info">
      {current.titleLogo ? (
        <h1 class="project-title project-title--logo">
          <img src={current.titleLogo} alt={current.alt} class="project-title-logo" />
        </h1>
      ) : (
        <h1 class="project-title">{current.title}</h1>
      )}
      {current.description &&
        (current.slug === "red-water" ? (
          current.description.split("\n\n").map((block) => (
            <p class="project-description">{block}</p>
          ))
        ) : (
          <p class="project-description">{current.description}</p>
        ))}
      {current.subtitle && (
        <p class="project-subtitle">{current.subtitle}</p>
      )}
    </div>

    {current.sections.map((section) =>
      section.type === "full-width" ? (
        <div class="section-fullwidth">
          {section.images.map((img, i) => (
            <img src={img} alt={`${current.title} — ${i + 1}`} class="fullwidth-img" />
          ))}
        </div>
      ) : section.type === "marquee" ? (
        <div class="marquee-wrap marquee-rtl">
          <div class="marquee-track">
            {section.images.map((img, i) => (
              <div class="marquee-item" data-swap-src={img}>
                <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" />
              </div>
            ))}
            {section.images.map((img, i) => (
              <div class="marquee-item" data-swap-src={img} aria-hidden="true">
                <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="section-masonry">
          {section.label && <p class="section-label">{section.label}</p>}
          <div class="masonry-grid">
            {section.images.map((img, i) => (
              <img src={img} alt={`${current.title} — ${i + 1}`} loading="lazy" class="masonry-img" />
            ))}
          </div>
        </div>
      )
    )}

    <div class="cta-section">
      <div class="cta-footer-nav">
        <a href="/services" class="footer-nav-link">services</a>
        <a href="/works" class="footer-nav-link">works</a>
      </div>
      <h2 class="cta-heading">Like what you see?</h2>
      <img src="/images/doodles/individual-doodle-2.png" alt="" class="cta-doodle-arrow" />
      <p class="cta-subheading">contact me!</p>
      <a href="mailto:shrutiada19@gmail.com" class="cta-email">shrutiada19@gmail.com</a>
      <a href="https://www.instagram.com" target="_blank" rel="noopener" class="cta-social">social media</a>
      <img src="/images/doodles/individual-doodle-1.png" alt="" class="cta-doodle-monster" />
    </div>

  </div>
</BaseLayout>

<style>
  .works-detail {
    width: 100%;
    overflow: hidden;
  }

  .project-info {
    padding: 6vw 8vw 4vw;
    text-align: center;
  }

  .project-title {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
  }

  .project-title--logo {
    margin: 0;
    line-height: 0;
  }

  .project-title-logo {
    width: 42vw;
    max-width: 90%;
    height: auto;
    display: inline-block;
    vertical-align: top;
    object-fit: contain;
  }

  .project-description {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 2vw;
    text-align: center;
    max-width: 72vw;
    margin-left: auto;
    margin-right: auto;
  }

  .project-subtitle {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    line-height: 1.4;
    margin-top: 2vw;
    text-align: center;
  }

  /* Full-width section */
  .section-fullwidth {
    padding: 3vw 8.3vw;
  }

  .fullwidth-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Marquee section */
  .marquee-wrap {
    width: 100%;
    overflow: hidden;
    padding: 3vw 0;
  }

  .marquee-track {
    display: flex;
    gap: 1.757vw;
    width: max-content;
  }

  .marquee-rtl .marquee-track {
    animation: scroll-rtl 140s linear infinite;
  }

  .marquee-wrap:hover .marquee-track {
    animation-play-state: paused;
  }

  .marquee-item {
    flex-shrink: 0;
    width: 40vw;
    overflow: hidden;
    border-radius: 2px;
    cursor: pointer;
  }

  .marquee-item img {
    width: 100%;
    height: 22vw;
    object-fit: cover;
    transition: transform 0.5s;
  }

  .marquee-item:hover img {
    transform: scale(1.03);
  }

  /* Masonry section */
  .section-masonry {
    padding: 3vw 4vw;
  }

  .section-label {
    font-family: "Sugarpie", cursive;
    font-size: 2.3443vw;
    font-weight: 400;
    text-align: left;
    margin-bottom: 2vw;
    padding-left: 0.5vw;
  }

  .masonry-grid {
    columns: 2;
    column-gap: 2vw;
  }

  .masonry-img {
    width: 100%;
    margin-bottom: 2vw;
    break-inside: avoid;
    display: block;
  }

  /* CTA section */
  .cta-section {
    position: relative;
    padding: 4vw 0 6vw;
    min-height: 57vw;
    overflow: visible;
  }

  .cta-heading {
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
  }

  .cta-doodle-arrow {
    position: absolute;
    left: 6vw;
    top: 5.8vw;
    width: 30vw;
    object-fit: contain;
    pointer-events: none;
  }

  .cta-subheading {
    position: relative;
    font-family: "NewUnderground", sans-serif;
    font-size: 4.6886vw;
    font-weight: 500;
    line-height: 1.057;
    text-align: center;
    margin-top: 12vw;
  }

  .cta-email {
    position: relative;
    display: block;
    margin-top: 1vw;
    font-family: "Sugarpie", cursive;
    font-size: 3.5139vw;
    font-weight: 400;
    text-decoration: none;
    color: inherit;
    text-align: center;
    transition: opacity 0.3s;
  }

  .cta-email:hover {
    opacity: 0.7;
  }

  .cta-doodle-monster {
    position: absolute;
    right: -4vw;
    top: 14vw;
    width: 37vw;
    object-fit: contain;
    pointer-events: none;
  }

  .cta-footer-nav { display: none; }
  .cta-social { display: none; }

  @keyframes scroll-rtl {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .project-info {
      padding: 38vw 6vw 4vw;
    }
    .project-title {
      font-size: 9.16vw;
    }

    .project-title-logo {
      width: 78vw;
      max-width: 92%;
    }
    .project-description {
      font-size: 4.07vw;
      max-width: 84.5vw;
      margin-top: 4vw;
    }
    .project-subtitle {
      font-size: 4.07vw;
    }

    .section-fullwidth {
      padding: 3vw 6vw;
    }

    .marquee-item { width: 46.1vw; }
    .marquee-item img { height: 26vw; }

    .section-masonry { padding: 3vw 6vw; }
    .masonry-grid { columns: 1; }
    .section-label { font-size: 4.07vw; }

    .cta-section {
      min-height: auto;
      padding: 8vw 6vw 10vw;
    }
    .cta-footer-nav {
      display: flex;
      justify-content: space-between;
      margin-bottom: 6vw;
    }
    .footer-nav-link {
      font-family: "Sugarpie", cursive;
      font-size: 4.07vw;
      color: inherit;
      text-decoration: none;
      transition: opacity 0.3s;
    }
    .footer-nav-link:hover { opacity: 0.6; }

    .cta-heading { font-size: 9.16vw; }
    .cta-doodle-arrow {
      left: auto;
      right: 2vw;
      top: 18vw;
      width: 41.2vw;
    }
    .cta-subheading {
      font-size: 9.16vw;
      margin-top: 8vw;
      text-align: left;
    }
    .cta-email {
      font-size: 4.58vw;
      text-align: center;
      margin-top: 3vw;
    }
    .cta-social {
      display: block;
      font-family: "Sugarpie", cursive;
      font-size: 4.07vw;
      text-align: center;
      text-decoration: none;
      color: inherit;
      margin-top: 3vw;
      transition: opacity 0.3s;
    }
    .cta-social:hover { opacity: 0.6; }
    .cta-doodle-monster {
      right: 2vw;
      top: 18vw;
      width: 41.2vw;
    }
  }

  /* Soleil Regular for body copy — Avid Bioservices & Red Water (except project intro) */
  .works-detail--avid-bio .project-description,
  .works-detail--avid-bio .project-subtitle,
  .works-detail--avid-bio .section-label,
  .works-detail--avid-bio .cta-email,
  .works-detail--avid-bio .cta-social,
  .works-detail--red-water .project-subtitle,
  .works-detail--red-water .section-label,
  .works-detail--red-water .cta-email,
  .works-detail--red-water .cta-social {
    font-family: "Soleil", ui-sans-serif, sans-serif;
  }

  .works-detail--red-water .project-description {
    font-family: Baskerville, "Libre Baskerville", "Baskerville Old Face", "Hoefler Text", Georgia, serif;
    font-weight: 400;
    font-style: normal;
    text-align: left;
    margin-left: 0;
    margin-right: auto;
  }

  .works-detail--red-water .project-description + .project-description {
    margin-top: 1.6vw;
  }

  .works-detail--avid-bio .project-subtitle,
  .works-detail--red-water .project-subtitle {
    text-align: left;
  }

  .works-detail--avid-bio .project-description {
    text-align: left;
    margin-left: 0;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .works-detail--avid-bio .footer-nav-link,
    .works-detail--red-water .footer-nav-link {
      font-family: "Soleil", ui-sans-serif, sans-serif;
    }
  }
</style>

<script>
  const fullwidthImg = document.querySelector('.fullwidth-img') as HTMLImageElement;
  if (fullwidthImg) {
    document.querySelectorAll('[data-swap-src]').forEach((el) => {
      el.addEventListener('click', () => {
        const src = (el as HTMLElement).dataset.swapSrc;
        if (src) {
          fullwidthImg.src = src;
          fullwidthImg.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    });
  }
</script>
